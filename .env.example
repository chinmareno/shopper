# ============================================================
# Docker Compose root env (only keys used by docker-compose.yml)
# ============================================================

# PostgreSQL
POSTGRES_DB=shopper
POSTGRES_USER=shopper
POSTGRES_PASSWORD=change-me-db-password

# Backend
# Allowed: development | production
BACKEND_NODE_ENV=development
CLIENT_URL=http://YOUR_VPS_IP_OR_DOMAIN:3000
# Comma-separated origins
ALLOWED_ORIGINS=http://YOUR_VPS_IP_OR_DOMAIN:3000,http://YOUR_VPS_IP_OR_DOMAIN:3001
BETTER_AUTH_URL=http://YOUR_VPS_IP_OR_DOMAIN:3001
BETTER_AUTH_SECRET=change-me-very-strong-secret
KOMERCE_API_URL=https://api-sandbox.collaborator.komerce.id/tariff/api/v1
KOMERCE_API_KEY=
BANK_ACCOUNT_NUMBER=1234567890
BANK_ACCOUNT_HOLDER=PT. Shopper Indonesia
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
# Allowed: false | true
MIDTRANS_IS_PRODUCTION=false
GOOGLE_SECRET=
GOOGLE_CLIENT=
GOOGLE_APP_EMAIL=
GOOGLE_APP_PASSWORD=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://YOUR_VPS_IP_OR_DOMAIN:3001
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
OPEN_CAGE_API_KEY=
UPLOADTHING_TOKEN=
